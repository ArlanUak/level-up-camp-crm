# Вставь сюда API-ключ из Google AI Studio
GEMINI_API_KEY=

# Модель можно не менять
GEMINI_MODEL=gemini-3.5-flash
GEMINI_SEARCH=true

# Стандартные аккаунты. После входа пароли можно поменять в интерфейсе.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=Арлан

TEACHER_USERNAME=teacher
TEACHER_PASSWORD=teacher123
TEACHER_NAME=Преподаватель

SMM_USERNAME=smm
SMM_PASSWORD=smm123
SMM_NAME=SMM

PORT=3001

# Cloud database for Render deployment. Leave empty for local SQLite.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

